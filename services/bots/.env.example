# Server
PORT=3030
HOST=127.0.0.1
DATABASE_URL=file:./data/bot-queue.db

# Admin auth (required) — generate a long random string
ADMIN_API_TOKEN=generate-a-long-random-string

# Lemmy instance
LEMMY_BASE_URL=https://api.vibecodecollab.com
# Local: http://localhost:1236

# @ai_tool_news_bot
AI_TOOL_NEWS_BOT_USERNAME=ai_tool_news_bot
AI_TOOL_NEWS_BOT_PASSWORD=
AI_TOOL_NEWS_COMMUNITY_ID=
# Lemmy community slug (path /c/<slug>), not the display title
AI_TOOL_NEWS_COMMUNITY_NAME=tools_and_workflows

# @github_projects_bot
GITHUB_PROJECTS_BOT_USERNAME=github_projects_bot
GITHUB_PROJECTS_BOT_PASSWORD=
GITHUB_PROJECTS_BOT_COMMUNITY_ID=
# Create this community on Lemmy first, or use another existing slug
GITHUB_PROJECTS_BOT_COMMUNITY_NAME=github_projects

# Content ingestion (optional — used by POST /admin/bot-posts/ingest and admin "Fetch new content")
# GitHub Search API: https://docs.github.com/en/rest/search/search#search-repositories
GITHUB_TOKEN=
GITHUB_SEARCH_QUERY=topic:ai+stars:>100
GITHUB_SEARCH_SORT=stars
GITHUB_SEARCH_PER_PAGE=10
GITHUB_MAX_AGE_DAYS=90

# AI tool news RSS feeds (comma-separated URLs)
AI_NEWS_RSS_URLS=https://openai.com/blog/rss.xml,https://www.anthropic.com/rss.xml
AI_NEWS_MAX_ITEMS_PER_FEED=5
AI_NEWS_MAX_AGE_DAYS=14

# AI summaries (optional — ingest works without OPENAI_API_KEY)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
SUMMARIZER_ENABLED=true
SUMMARY_MIN_SOURCE_CHARS=200
SUMMARY_MAX_OUTPUT_CHARS=300
PAGE_FETCH_TIMEOUT_MS=10000
PAGE_FETCH_MAX_BYTES=500000
