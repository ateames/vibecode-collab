# Server
PORT=3030
HOST=127.0.0.1
DATABASE_URL=file:./data/bot-queue.db

# Admin auth (required) — generate a long random string
ADMIN_API_TOKEN=generate-a-long-random-string

# Lemmy instance
LEMMY_BASE_URL=https://api.vibecodecollab.com
# Local: http://localhost:1236

# @ai_tool_news_bot
AI_TOOL_NEWS_BOT_USERNAME=ai_tool_news_bot
AI_TOOL_NEWS_BOT_PASSWORD=
AI_TOOL_NEWS_COMMUNITY_ID=
# Lemmy community slug (path /c/<slug>), not the display title
AI_TOOL_NEWS_COMMUNITY_NAME=tools_and_workflows

# @github_projects_bot
GITHUB_PROJECTS_BOT_USERNAME=github_projects_bot
GITHUB_PROJECTS_BOT_PASSWORD=
GITHUB_PROJECTS_BOT_COMMUNITY_ID=
# Create this community on Lemmy first, or use another existing slug
GITHUB_PROJECTS_BOT_COMMUNITY_NAME=github_projects
