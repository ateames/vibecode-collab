# Copy to .env for local reference (this file is safe to commit).
# Blorp build-time variables go in blorp/.env — see docs/deployment.md.

# --- Your instance (fill in before deploy) ---
LEMMY_HOSTNAME=lemmy.example.com
BLORP_HOSTNAME=app.example.com

# --- GitHub (your forks — update after creating repos) ---
GITHUB_USER=your-github-username
LEMMY_REPO=https://github.com/${GITHUB_USER}/lemmy.git
BLORP_REPO=https://github.com/${GITHUB_USER}/blorp.git

# --- Blorp → Lemmy (used at Cloudflare Pages build time) ---
REACT_APP_NAME=My Lemmy Instance
REACT_APP_DEFAULT_INSTANCE=https://lemmy.example.com
REACT_APP_LOCK_TO_DEFAULT_INSTANCE=1
REACT_APP_INSTANCE_SELECTION_MODE=default_first
