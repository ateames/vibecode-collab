# Copy to deploy/digitalocean/.env on the droplet (or export before running setup).
# Do not commit deploy/digitalocean/.env

LEMMY_HOSTNAME=api.vibecodecollab.com
LEMMY_REPO=https://github.com/LemmyNet/lemmy.git
LEMMY_IMAGE_TAG=0.19.18

BLORP_ORIGIN_APEX=https://vibecodecollab.com
BLORP_ORIGIN_WWW=https://www.vibecodecollab.com

SITE_NAME=Vibe Code Collab
ADMIN_USERNAME=admin
# ADMIN_PASSWORD — generated by setup-lemmy.sh if unset (min 10 chars)

# Postgres / pictrs — generated if unset
# POSTGRES_PASSWORD=
# PICTRS_API_KEY=
