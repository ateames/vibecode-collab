# Copy to deploy/cloudflare/.env (gitignored). Used by scripts/deploy-cloudflare-pages.sh
#
# Cloudflare Dashboard → Workers & Pages → your project → name in the URL/sidebar.

# Required: Pages project name (must match an existing Pages project in your account)
CLOUDFLARE_PAGES_PROJECT_NAME=your-blorp-pages-project

# Optional: production branch (default: main). Use "production" if your Pages project uses that branch name.
CLOUDFLARE_PAGES_BRANCH=main

# Optional: account ID if you have multiple Cloudflare accounts (wrangler whoami lists accounts)
# CLOUDFLARE_ACCOUNT_ID=
