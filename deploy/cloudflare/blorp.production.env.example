# Copy to blorp/.env.production (gitignored in blorp). Loaded by Vite for `pnpm build:web:prod`.
# Values are baked into the static build — change requires rebuild + redeploy.

REACT_APP_NAME=Vibe Code Collab
REACT_APP_TAGLINE=A collaborative threadiverse client
REACT_APP_PUBLIC_URL=https://vibecodecollab.com
REACT_APP_SUPPORT_EMAIL=support@vibecodecollab.com
# REACT_APP_GITHUB_REPO=https://github.com/your-github-username/blorp
REACT_APP_DEFAULT_INSTANCE=https://api.vibecodecollab.com
REACT_APP_HOST=vibecodecollab.com
REACT_APP_LOCK_TO_DEFAULT_INSTANCE=1
REACT_APP_INSTANCE_SELECTION_MODE=default_first

# Optional
# REACT_APP_CONTENT_WARNING=
# REACT_APP_HOST=app.example.com
